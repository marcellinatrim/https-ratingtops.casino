---
// Footer.astro — Подвал сайта
const footerNav = [
  { href: '/', label: 'Все казино' },
  { href: '/min-depozit', label: 'Мин. депозит' },
  { href: '/mobilnye', label: 'Мобильные' },
  { href: '/s-litsenziei', label: 'С лицензией' },
  { href: '/demo-bez-registracii', label: 'Демо' },
  { href: '/about', label: 'О нас' },
  { href: '/privacy', label: 'Политика' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <!-- Бренд -->
      <div class="footer-brand">
        <div class="footer-logo">Казино<span>Рейтинг</span></div>
        <div class="footer-tagline">Независимый агрегатор · Обновляется ежемесячно</div>
      </div>

      <!-- Навигация -->
      <nav aria-label="Навигация в подвале">
        <ul class="footer-nav">
          {footerNav.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Дисклеймер -->
    <div class="footer-disclaimer">
      <p>
        © {currentYear} КазиноРейтинг — независимый агрегатор онлайн-казино.
        Все материалы носят информационный характер.
        Мы можем получать комиссию за переходы по партнёрским ссылкам — это не влияет на объективность оценок.
      </p>
      <p>
        <strong>18+</strong> Игорная деятельность сопряжена с риском. Играйте ответственно.
        При наличии признаков игровой зависимости обратитесь за помощью к специалисту.
      </p>
    </div>
  </div>
</footer>
