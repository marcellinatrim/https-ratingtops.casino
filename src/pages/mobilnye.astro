---
// src/pages/mobilnye.astro — Мобильные казино
// ФИЛЬТР: is_mobile_friendly === true
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();

const casinos = [...casinosRaw]
  .filter(c => c.is_mobile_friendly === true)
  .sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: 'Нужно ли скачивать приложение казино?',
    a: 'Нет. Большинство современных казино работают прямо в браузере смартфона. Некоторые дополнительно предлагают нативные приложения для iOS и Android.',
  },
  {
    q: 'Какие казино лучше всего работают на смартфоне?',
    a: 'Все казино в этом списке прошли проверку на корректную работу в мобильном браузере. Интерфейс адаптирован для сенсорных экранов, загрузка оптимизирована.',
  },
  {
    q: 'Безопасно ли играть в казино с телефона?',
    a: 'Да, при использовании надёжного соединения и официального сайта казино. Все рекомендованные площадки используют SSL-шифрование для защиты данных.',
  },
];
---

<BaseLayout
  title={`Мобильные казино ${buildYear} — Лучшие казино для смартфона`}
  description={`Топ ${casinos.length} казино с удобной мобильной версией для Android и iOS. Играйте на смартфоне без скачивания приложения. Обновлено: ${buildMonth}.`}
  activePage="/mobilnye"
>

  <section id="hero">
    <div class="container">
      <h1><em>Мобильные казино</em> {buildYear} — играйте на смартфоне</h1>
      <p>
        {casinos.length} казино с удобной мобильной версией.
        Никаких приложений — играйте прямо в браузере.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Казино с мобильной версией ({casinos.length} шт.)</h2>
      <div class="page-meta">
        <span class="page-meta__badge">📱 Мобильные</span>
        <span>Найдено: {casinos.length} казино</span>
      </div>
      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content">
    <div class="container">
      <h2>Мобильные казино: как выбрать лучшее в {buildYear} году?</h2>
      <p>
        Мобильные казино сегодня практически не уступают десктопным. Современные HTML5-слоты
        адаптированы под сенсорные экраны, а интерфейс оптимизирован для небольших дисплеев.
      </p>
      <h3>Мобильный браузер vs. приложение</h3>
      <p>
        Браузерная версия не требует установки и обновляется автоматически. Нативное приложение
        работает быстрее и поддерживает push-уведомления о бонусах. Выбор за вами.
      </p>
      <h3>Какие слоты доступны на мобильном?</h3>
      <p>
        Все слоты от ведущих провайдеров (Pragmatic Play, Evolution, NetEnt) поддерживают
        мобильные устройства. Живые игры с дилерами также доступны при стабильном интернете.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} heading="FAQ: Мобильные казино" />

</BaseLayout>
