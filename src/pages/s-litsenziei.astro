---
// src/pages/s-litsenziei.astro — Казино с лицензией
// ФИЛЬТР: has_license === true
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';

// ---- ЛОГИКА КЛАСТЕРА ----
const casinos = [...casinosRaw]
  .filter(c => c.has_license === true)
  .sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: 'Что даёт лицензия казино игроку?',
    a: 'Лицензия означает, что казино прошло проверку регулятором: генератор случайных чисел сертифицирован, выплаты гарантированы, данные игроков защищены. Это снижает риск мошенничества.',
  },
  {
    q: 'Какие лицензии считаются надёжными?',
    a: 'Наиболее авторитетные лицензии выдают: Malta Gaming Authority (MGA), UK Gambling Commission, Curaçao eGaming. Казино с лицензией MGA или UKGC считаются наиболее надёжными.',
  },
  {
    q: 'Как проверить лицензию казино?',
    a: 'Номер лицензии указывается в подвале сайта казино. Вы можете проверить его на официальном сайте регулятора. Все казино в нашем рейтинге прошли эту проверку.',
  },
];
---

<BaseLayout
  title="Лицензированные казино 2024 — Рейтинг надёжных площадок"
  description={`${casinos.length} казино с действующей лицензией. Проверенные площадки с гарантированными выплатами и защитой игрока.`}
  activePage="/s-litsenziei"
>

  <section id="hero">
    <div class="container">
      <h1>Казино <em>с лицензией</em> — Только проверенные площадки</h1>
      <p>
        {casinos.length} казино с действующей лицензией.
        Гарантированные выплаты и честная игра.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Лицензированные казино ({casinos.length} шт.)</h2>

      <div class="page-meta">
        <span class="page-meta__badge">✅ Лицензия подтверждена</span>
        <span>Найдено: {casinos.length} казино</span>
      </div>

      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content">
    <div class="container">
      <h2>Почему важно играть в лицензированных казино?</h2>
      <p>
        Лицензия — это гарантия того, что казино работает по правилам и под надзором
        регулятора. Нелицензированные площадки могут заморозить ваш счёт без объяснений.
        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>

      <h3>Как регулятор защищает игроков?</h3>
      <p>
        При наличии лицензии игрок может подать официальную жалобу регулятору, если казино
        отказывается выплачивать выигрыш. Регулятор проводит расследование и может отозвать
        лицензию у нарушителя.
      </p>

      <h3>Лицензия и честность RNG</h3>
      <p>
        Генератор случайных чисел (RNG) в лицензированных казино регулярно тестируется
        независимыми аудиторами (eCOGRA, BMM Testlabs). Это гарантирует честность каждого
        спина и честный теоретический процент отдачи (RTP).
      </p>
    </div>
  </section>

  <FAQ items={faqItems} heading="FAQ: Казино с лицензией" />

</BaseLayout>
