---
// BaseLayout.astro — базовая обёртка всех страниц
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  activePage?: string;
}

const { title, description, activePage = '' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!--
    ANTI-FOUC: Читаем тему из localStorage ДО рендера.
    Скрипт инлайновый и блокирующий — это намеренно,
    чтобы <html> получил data-theme до первой отрисовки.
  -->
  <script is:inline>
    (function() {
      try {
        var saved = localStorage.getItem('theme');
        var theme = saved === 'dark' || saved === 'light'
          ? saved
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <!--
    NETWORK INFORMATION API: Определяем скорость соединения ДО рендера.
    При slow-2g / 2g / 3g добавляем класс .low-connection на <html>.
    CSS по этому классу:
      – отключает загрузку веб-шрифтов (откат на system-ui)
      – убирает тени и градиенты (hero → solid color)
    Результат: мгновенная отрисовка на слабой сети → нет отказов → ПФ растут.

    Скрипт инлайновый и синхронный — выполняется до первого рендера,
    поэтому браузер никогда не запрашивает шрифты при плохом соединении.
  -->
  <script is:inline>
    (function() {
      try {
        var conn = navigator.connection
          || navigator.mozConnection
          || navigator.webkitConnection;
        if (conn) {
          var slow = ['slow-2g', '2g', '3g'];
          if (slow.indexOf(conn.effectiveType) !== -1) {
            document.documentElement.classList.add('low-connection');
          }
          // Отслеживаем динамическое изменение сети (например, въехал в тоннель)
          conn.addEventListener('change', function() {
            if (slow.indexOf(conn.effectiveType) !== -1) {
              document.documentElement.classList.add('low-connection');
            } else {
              document.documentElement.classList.remove('low-connection');
            }
          });
        }
      } catch(e) {
        // API недоступно — ничего не делаем, грузим полный дизайн
      }
    })();
  </script>

  <!-- Schema.org: WebSite -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "КазиноРейтинг",
      "url": "https://example.com"
    }
  </script>
</head>
<body>
  <Header activePage={activePage} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
