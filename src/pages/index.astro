---
// src/pages/index.astro — Главная страница
// Выводит ВСЕ казино из casinos.json, отсортированные по рейтингу (desc)
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';

// ── Build-time утилиты ──────────────────────────────────────────────────────
// Выполняются ТОЛЬКО в Node.js при сборке. В HTML попадают готовые строки.
import { getBuildMonth, getBuildYear, getBuildDateISO, getBuildDateFull } from '../utils/date';

const buildMonth = getBuildMonth();   // "Март 2026"
const buildYear  = getBuildYear();    // 2026
const buildISO   = getBuildDateISO(); // "2026-03-19"
const buildFull  = getBuildDateFull();// "19 марта 2026"

// ---- ЕДИНСТВЕННОЕ МЕСТО СОРТИРОВКИ ----
const casinos = [...casinosRaw].sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: `Как выбрать надёжное онлайн-казино в ${buildYear} году?`,
    a: 'При выборе казино обращайте внимание на наличие лицензии, репутацию среди игроков, скорость выплат и качество службы поддержки. Наш рейтинг учитывает все эти параметры и обновляется ежемесячно.',
  },
  {
    q: 'Какой минимальный депозит в казино из рейтинга?',
    a: 'Среди казино в нашем рейтинге минимальный депозит начинается от 30 рублей. Список казино с минимальным депозитом до 100 рублей доступен в соответствующем разделе.',
  },
  {
    q: 'Можно ли играть в казино без регистрации?',
    a: 'Да, часть казино из нашего рейтинга предоставляет демо-режим без регистрации. Это позволяет попробовать слоты бесплатно до пополнения счёта.',
  },
  {
    q: 'Как работают фриспины в бонусе?',
    a: 'Фриспины (FS) — это бесплатные вращения в слотах. Казино начисляет их при регистрации или первом депозите. Выигрыш от фриспинов обычно нужно отыграть согласно вейджеру, указанному в условиях.',
  },
];
---

<BaseLayout
  title={`Лучшие онлайн-казино ${buildYear} — Рейтинг и бонусы | КазиноРейтинг`}
  description={`Независимый рейтинг лучших онлайн-казино для игроков из России. Актуальные бонусы, быстрые выплаты, проверенные лицензии. Обновлено: ${buildMonth}.`}
  activePage="/"
>

  <!-- 1. HERO -->
  <section id="hero">
    <div class="container">
      <h1>Рейтинг лучших <em>онлайн-казино</em> в {buildYear} году</h1>
      <p>
        Независимая экспертная оценка {casinos.length} казино. Актуальные бонусы,
        честные выплаты, только проверенные площадки.
      </p>
    </div>
  </section>

  <!-- 2. РЕЙТИНГ — динамически из JSON -->
  <section id="rating">
    <div class="container">
      <h2>Топ казино — все {casinos.length} площадок</h2>

      <div class="page-meta">
        <span class="page-meta__badge">Обновлено: {buildMonth}</span>
        <span>Актуально на {buildFull} · Сортировка по рейтингу</span>
      </div>

      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. SEO-КОНТЕНТ -->
  <section id="seo-content" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="dateModified" content={buildISO} />
    <div class="container">
      <h2>Как мы составляем рейтинг казино в {buildYear} году?</h2>
      <p>
        Наша редакция ежемесячно анализирует более 50 площадок по более чем 30 параметрам.
        В рейтинг попадают только те казино, которые прошли проверку по ключевым критериям.
      </p>

      <h3>Критерии отбора</h3>
      <p>
        Мы оцениваем лицензионную чистоту, скорость обработки заявок на вывод средств,
        ширину игровой библиотеки, качество мобильной версии и прозрачность условий бонусов.
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
        incididunt ut labore et dolore magna aliqua.
      </p>

      <h3>Методология оценки бонусов</h3>
      <p>
        Бонусные предложения оцениваются не только по размеру, но и по реальной ценности:
        вейджер, допустимые игры для отыгрыша, максимальная сумма вывода бонусных средств.
        Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip.
      </p>

      <h3>Как часто обновляется рейтинг?</h3>
      <p>
        Рейтинг обновляется ежемесячно. При изменении условий работы казино (новые жалобы
        игроков, изменение политики выплат, потеря лицензии) мы вносим изменения незамедлительно.
      </p>
    </div>
  </section>

  <!-- 4. FAQ -->
  <FAQ items={faqItems} />

</BaseLayout>
