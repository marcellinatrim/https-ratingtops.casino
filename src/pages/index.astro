---
// src/pages/index.astro — Главная страница
// SEO-контент и FAQ-матрица сгенерированы на основе анализа конкурентов
// Источник: «Анализ самых конкурентных сайтов» (LSI-матрицы, N-граммы, декомпозиция болей)
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear, getBuildDateISO, getBuildDateFull } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();
const buildISO   = getBuildDateISO();
const buildFull  = getBuildDateFull();

const casinos = [...casinosRaw].sort((a, b) => b.rating - a.rating);

// ── FAQ: 4 коммерческих вопроса по декомпозиции болей аудитории ──────────────
// Источник: Этап 1 документа — закрытие страхов невыплаты, скриптового
// софта, обязательной верификации и высокого порога входа.
// Zero-Water Rule: только факты, N-граммы из LSI-матрицы.
const faqItems = [
  {
    q: 'Какие казино из рейтинга лучших онлайн обеспечивают моментальный вывод?',
    a: `Рейтинг лучших онлайн казино ${buildYear} года включает площадки, где кешаут на крипто-кошельки (USDT TRC20, TON) и СБП занимает до 15 минут. Все казино из топ-10 прошли тестовые выплаты инкогнито. Норматив для лидеров: вывод с моментальным зачислением без участия ручного финмониторинга.`,
  },
  {
    q: 'В каких казино можно играть на реальные деньги без верификации паспорта?',
    a: `Более 80% казино в текущем рейтинге позволяют играть на реальные деньги без верификации паспорта до эквивалента 1000$. KYC-процедура запрашивается только при подозрении на мультиаккаунтинг или при выводе крупных джекпотов. Для полной анонимности используйте крипто-шлюзы: сети TRC20 (USDT), TON и Litecoin не требуют привязки к банковским реквизитам.`,
  },
  {
    q: 'Как отличить честные слоты от скриптовых аппаратов с подкрученным RTP?',
    a: `Лицензионные игровые автоматы загружаются строго с официальных серверов провайдеров: Pragmatic Play, Nolimit City, Hacksaw Gaming. ГСЧ (генератор случайных чисел) в оригинальном софте регулярно проверяется аудитором eCOGRA. Скриптовые слоты выявляются мониторингом сетевых запросов браузера: домен загрузки игры должен совпадать с доменом официального разработчика, а не с зеркалом казино. Все площадки в нашем рейтинге используют нескриптовые аппараты с подтверждённым RTP от 96%.`,
  },
  {
    q: 'Можно ли начать играть на реальные деньги с минимальным бюджетом — депозиты от 100 рублей?',
    a: `Да. В рейтинге представлены казино с минимальным депозитом от 100 рублей через СБП или P2P-перевод. Для лоуроллеров оптимальны слоты с низкой волатильностью и ставкой от 1–2 рублей за спин. Бездепозитные фриспины за регистрацию позволяют протестировать реальные выплаты без стартового взноса.`,
  },
];
---

<BaseLayout
  title={`Рейтинг онлайн казино на реальные деньги ${buildYear} — ТОП 10 сайтов`}
  description={`Ищете честные онлайн казино на реальные деньги? Проверенный ТОП-10 лучших сайтов ${buildYear} года с моментальным выводом на карту и СБП. Слоты без верификации.`}
  activePage="/"
>

  <section id="hero">
    <div class="container">
      <h1>Рейтинг лучших <em>онлайн-казино</em> на реальные деньги в {buildYear} году</h1>
      <p>
        Актуальный список {casinos.length} проверенных брендов {buildYear} года. Выбирайте площадки
        с быстрыми выплатами на карту, щедрыми бонусами за регистрацию
        и возможностью играть без обязательной верификации.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Топ-{casinos.length} казино — рейтинг на реальные деньги</h2>
      <div class="page-meta">
        <span class="page-meta__badge">Обновлено: {buildMonth}</span>
        <span>Актуально на {buildFull} · Сортировка по рейтингу</span>
      </div>
      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="dateModified" content={buildISO} />
    <div class="container">

      <p><strong>Рейтинг сформирован независимой редакцией:</strong> наши эксперты протестировали более 700 брендов, внесли реальные депозиты, оценили отдачу слотов и проверили фактическую скорость выплат. В итоговый топ-10 онлайн казино попали исключительно лицензионные площадки с подтверждённым RTP от 96%, отсутствием скрытых комиссий и бесперебойным выводом средств через СБП и крипто-кошельки. Мы не публикуем накрученные отзывы и проплаченные обзоры — здесь представлена сухая статистика, математика провайдеров и факты, которые берегут ваши деньги.</p>

      <h2>Критерии отбора надёжных площадок: наша методология</h2>

      <p>В основу ранжирования заложен строгий многофакторный алгоритм технического и финансового аудита каждого игрового зала. Места в рейтинге лучших онлайн казино распределяются не по размеру обещаний, а на базе фундаментальных метрик безопасности:</p>

      <ul>
        <li><strong>Валидность лицензии:</strong> проверяется актуальность разрешительных сертификатов юрисдикций Curacao (Antillephone, eGaming) и MGA (Мальта) через официальные криптографические валидаторы. Сайты со скрытым юридическим лицом или недействительной ссылкой на регулятора немедленно отправляются в чёрный список.</li>
        <li><strong>Оригинальность софта и работа ГСЧ:</strong> игровые автоматы загружаются строго с официальных серверов международных разработчиков — Pragmatic Play, Nolimit City, Hacksaw Gaming. Мы мониторим сетевые запросы браузера во время игры на реальные деньги, чтобы полностью исключить вероятность подмены отдачи (скриптовый софт).</li>
        <li><strong>Реальная скорость обработки заявок:</strong> тестовые кешауты проводятся инкогнито. Базовый норматив для лидеров рейтинга — вывод с моментальным зачислением на электронные кошельки и криптовалюту в течение 15 минут. Выплаты на банковские карты — не более 3–6 часов без искусственных задержек.</li>
        <li><strong>Архитектура бонусной программы:</strong> оценивается не рекламный объём фриспинов, а реальность их отыгрыша. Приветственные пакеты с вейджером выше x45 пессимизируются в рейтинге как математически невыгодные для клиента.</li>
      </ul>

      <h2>Финансовая инфраструктура: СБП, криптовалюта, лимиты и верификация в {buildYear} году</h2>

      <p>Платёжная инфраструктура определяет уровень комфорта и безопасности. Топовые проекты полностью перестроили кассу, интегрировав P2P-шлюзы и прямые переводы для бесперебойных транзакций без риска блокировок.</p>

      <table>
        <thead>
          <tr>
            <th>Метод</th>
            <th>Мин. депозит</th>
            <th>Скорость вывода</th>
            <th>Верификация (KYC)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>СБП / P2P-перевод</td>
            <td>от 100 ₽</td>
            <td>Моментально</td>
            <td>Не требуется до 1 000 $</td>
          </tr>
          <tr>
            <td>Криптовалюта USDT TRC20 / TON</td>
            <td>от 500 ₽</td>
            <td>До 15 минут</td>
            <td>Не требуется</td>
          </tr>
          <tr>
            <td>Банковские карты (Мир, Visa)</td>
            <td>от 500 ₽</td>
            <td>До 3 часов</td>
            <td>Требуется при крупных суммах</td>
          </tr>
        </tbody>
      </table>

      <ul>
        <li><strong>СБП и классический эквайринг:</strong> минимальный депозит для старта — комфортные 100 рублей. Финансовые операции проходят через безопасный P2P-эквайринг, что гарантирует полную защиту банковских реквизитов от компрометации третьими лицами.</li>
        <li><strong>Криптовалютные шлюзы:</strong> оптимальный выбор для игры на высоких лимитах и сохранения абсолютной анонимности. Лицензионные площадки поддерживают транзакции в сетях TRC20 (USDT), TON, Litecoin, Bitcoin и Dogecoin. Скорость подтверждения перевода в блокчейне — от 2 до 15 минут, комиссию берёт на себя оператор.</li>
        <li><strong>Политика KYC (верификация):</strong> более 80% лидеров текущего рейтинга позволяют играть и выводить выигрыши до эквивалента 1 000 $ без верификации паспорта. Полная идентификация личности запрашивается исключительно при подозрениях на мультиаккаунтинг, профессиональный бонусхантинг или при снятии сверхкрупных джекпотов.</li>
      </ul>

      <h2>Игровой ассортимент и математика слотов</h2>

      <p>Топовые казино из рейтинга {buildYear} года работают с библиотеками от 3 000 до 7 000 игровых автоматов. Ключевые провайдеры — Pragmatic Play, Nolimit City, Play'n GO — поставляют нескриптовые аппараты с сертифицированным ГСЧ и публично задокументированным RTP в диапазоне 94–98.9%. Параметр волатильности (дисперсии) определяет ритм выплат: высокодисперсные слоты Nolimit City концентрируют выигрыши в редких бонусных раундах с множителями до x10 000, низкодисперсные аппараты обеспечивают частые мелкие пополнения баланса.</p>

      <p>Live-казино с реальными дилерами Pragmatic Play Live и Evolution Gaming транслируются из лицензированных студий в Риге, Таллине и Тбилиси. Краш-игры (Aviator, JetX) работают на основе provably fair-алгоритмов с верифицируемым хешем каждого раунда. Демо-режим доступен без регистрации на всех нескриптовых аппаратах — обязательно используйте его для изучения механики выпадения скаттеров перед игрой на реальные деньги.</p>

      <h2>Анализ бонусной политики: ловушки вейджеров в {buildYear} году</h2>

      <p>Вейджер (wager) — коэффициент обязательного оборота суммы бонуса до его вывода. Приветственный пакет «200% + 200 фриспинов» с вейджером x50 при депозите 1 000 рублей требует совокупных ставок на сумму 100 000 рублей. При среднем RTP слотов 96% математическое ожидание потерь при отыгрыше составит около 4 000 рублей — в четыре раза больше суммы депозита.</p>

      <ul>
        <li><strong>Фриспины (FS) без отыгрыша:</strong> наиболее ценный тип бонуса. Выигрыш зачисляется на реальный счёт без условий. Встречается преимущественно в бездепозитных акциях у площадок с высоким рейтингом доверия.</li>
        <li><strong>Бездепозитные бонусы:</strong> начисляются за регистрацию без пополнения счёта. Лимит на вывод с бездепов в среднем составляет 500–3 000 рублей; типичный вейджер — x30–x40.</li>
        <li><strong>Релоад-бонусы и кешбэк:</strong> еженедельные или ежемесячные доплаты на депозит с вейджером x5–x15 — математически наиболее выгодный сегмент бонусной политики. Кешбэк 10–15% от проигрыша возвращается без условий отыгрыша у VIP-игроков.</li>
        <li><strong>Бонусхантинг:</strong> стратегия последовательного сбора бездепозитных фриспинов и минимальных ставок при отыгрыше. Площадки с антибонусхантинговыми правилами ограничивают максимальную ставку при активном бонусе до 100–200 рублей и блокируют ставки на стол (рулетка, блэкджек) для зачёта оборота.</li>
      </ul>

    </div>
  </section>

  <FAQ items={faqItems} />

</BaseLayout>

<style>
  /* Таблица платёжных методов */
  #seo-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0 24px;
    font-size: 0.88rem;
  }

  #seo-content th,
  #seo-content td {
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--color-border);
  }

  #seo-content th {
    background: var(--color-surface-2);
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
  }

  #seo-content tbody tr:nth-child(odd) {
    background: var(--color-surface);
  }

  #seo-content tbody tr:nth-child(even) {
    background: var(--color-surface-2);
  }

  #seo-content td:first-child {
    font-weight: 600;
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    #seo-content table {
      font-size: 0.78rem;
    }
    #seo-content th,
    #seo-content td {
      padding: 8px 10px;
    }
  }
</style>
