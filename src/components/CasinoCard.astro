---
// CasinoCard.astro — Карточка казино
// Mobile: Card UI / Desktop: Row UI (через CSS grid + display:contents)
// Данные приходят из casinos.json через Astro.props — не хардкодим

// ── Build-time утилиты ──────────────────────────────────────────────────────
// Импорты выполняются ТОЛЬКО в Node.js во время сборки.
// В скомпилированный HTML попадают уже готовые строки — без JS на клиенте.
import { generateRtp } from '../utils/rtp';

interface Casino {
  id: string;
  name: string;
  logo: string;
  rating: number;
  min_deposit: number;
  bonus_text: string;
  features: string[];
  go_link: string;
  is_mobile_friendly: boolean;
  has_license: boolean;
  no_registration_demo: boolean;
}

interface Props {
  casino: Casino;
  rank: number;
}

const { casino, rank } = Astro.props;

// Звёзды рейтинга (одна знаковая звезда + число)
const ratingDisplay = `★ ${casino.rating.toFixed(1)}`;

// ── Build-time RTP ─────────────────────────────────────────────────────────
// Вычисляется один раз при сборке. Вшивается в HTML как статичный текст.
// Детерминирован в рамках одной сборки, меняется каждый месяц (freshness).
const casinoRtp = generateRtp(casino.id);

// ── Логотип: пропорции для CLS-защиты ─────────────────────────────────────
// CSS задаёт logo 64×40px (mobile) / 84×48px (desktop).
// Указываем наибольший размер — браузер зарезервирует место до загрузки.
const LOGO_W = 84;
const LOGO_H = 48;
---

<article class="casino-card" id={`casino-${casino.id}`}>

  <!-- Ранг -->
  <div class="casino-card__rank" aria-label={`Позиция в рейтинге: ${rank}`}>
    #{rank}
  </div>

  <!-- Логотип
       width/height — резервируют место ДО загрузки → нет CLS.
       loading="lazy" — не блокирует LCP основного контента.
       decoding="async" — декодирование в фоне, не блокирует main thread.
  -->
  <div class="casino-card__logo">
    <img
      src={casino.logo}
      alt={`Логотип ${casino.name}`}
      width={LOGO_W}
      height={LOGO_H}
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Название + теги -->
  <div class="casino-card__info">
    <div class="casino-card__name">{casino.name}</div>
    <div class="casino-card__features">
      {casino.features.map(tag => (
        <span class="casino-card__tag">{tag}</span>
      ))}
      {casino.is_mobile_friendly && (
        <span class="casino-card__tag">📱 Моб.</span>
      )}
      {casino.has_license && (
        <span class="casino-card__tag">✅ Лицензия</span>
      )}
      {casino.no_registration_demo && (
        <span class="casino-card__tag">🎮 Демо</span>
      )}
    </div>
  </div>

  <!-- Бонус -->
  <div class="casino-card__bonus">
    {casino.bonus_text}
  </div>

  <!--
    .casino-card__meta — обёртка для мобайл.
    На десктопе получает display:contents, и дочерние элементы
    (.casino-card__deposit, .casino-card__rating) становятся
    прямыми участниками grid-родителя, занимая свои grid-area.
  -->
  <div class="casino-card__meta">
    <div class="casino-card__deposit">
      <strong>{casino.min_deposit} ₽</strong>
      мин. депозит
    </div>
    <!-- RTP: число вшито в HTML при сборке, клиентского JS нет -->
    <div class="casino-card__rtp" title="Теоретический процент отдачи (вшит при сборке)">
      RTP: {casinoRtp}%
    </div>
    <div class="casino-card__rating" title="Рейтинг экспертов">
      {ratingDisplay}
    </div>
  </div>

  <!-- CTA -->
  <a
    href={casino.go_link}
    class="casino-card__cta"
    rel="nofollow noopener sponsored"
    target="_blank"
    aria-label={`Играть в ${casino.name}`}
  >
    Играть →
  </a>

</article>
