---
// src/pages/index.astro — Главная страница
// Все 15 казино, сортировка по убыванию rating
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear, getBuildDateISO, getBuildDateFull } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();
const buildISO   = getBuildDateISO();
const buildFull  = getBuildDateFull();

const casinos = [...casinosRaw].sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: `Как выбрать надёжное онлайн-казино в ${buildYear} году?`,
    a: 'При выборе казино обращайте внимание на лицензию, репутацию среди игроков, скорость выплат и качество поддержки. Наш рейтинг учитывает все эти параметры и обновляется ежемесячно.',
  },
  {
    q: 'Какой минимальный депозит в казино из рейтинга?',
    a: 'Среди казино в нашем рейтинге минимальный депозит начинается от 50 рублей. Список казино с минимальным депозитом до 100 рублей — в соответствующем разделе.',
  },
  {
    q: 'Можно ли играть в казино без регистрации?',
    a: 'Да, часть казино предоставляет демо-режим без регистрации. Это позволяет попробовать слоты бесплатно до пополнения счёта.',
  },
  {
    q: 'Как работают фриспины в бонусе?',
    a: 'Фриспины — бесплатные вращения в слотах. Казино начисляет их при регистрации или первом депозите. Выигрыш отыгрывается согласно вейджеру, указанному в условиях акции.',
  },
];
---

<BaseLayout
  title={`Лучшие онлайн-казино ${buildYear} — Рейтинг и бонусы | КазиноРейтинг`}
  description={`Независимый рейтинг ${casinos.length} лучших онлайн-казино. Актуальные бонусы, быстрые выплаты, проверенные лицензии. Обновлено: ${buildMonth}.`}
  activePage="/"
>

  <section id="hero">
    <div class="container">
      <h1>Рейтинг лучших <em>онлайн-казино</em> в {buildYear} году</h1>
      <p>
        Независимая экспертная оценка {casinos.length} казино. Актуальные бонусы,
        честные выплаты, только проверенные площадки.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Топ-{casinos.length} казино — полный рейтинг</h2>
      <div class="page-meta">
        <span class="page-meta__badge">Обновлено: {buildMonth}</span>
        <span>Актуально на {buildFull} · Сортировка по рейтингу</span>
      </div>
      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="dateModified" content={buildISO} />
    <div class="container">
      <h2>Как мы составляем рейтинг казино в {buildYear} году?</h2>
      <p>
        Наша редакция ежемесячно анализирует более 50 площадок по 30+ параметрам.
        В рейтинг попадают только казино, прошедшие проверку по ключевым критериям.
      </p>
      <h3>Критерии отбора</h3>
      <p>
        Мы оцениваем лицензионную чистоту, скорость обработки заявок на вывод,
        ширину игровой библиотеки, качество мобильной версии и прозрачность условий бонусов.
      </p>
      <h3>Методология оценки бонусов</h3>
      <p>
        Бонусы оцениваются не только по размеру, но и по реальной ценности: вейджер,
        допустимые игры для отыгрыша, максимальная сумма вывода бонусных средств.
      </p>
      <h3>Как часто обновляется рейтинг?</h3>
      <p>
        Рейтинг обновляется ежемесячно. При изменении условий казино — новые жалобы игроков,
        изменение политики выплат, потеря лицензии — вносим изменения незамедлительно.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} />

</BaseLayout>
