// src/pages/index.astro — Главная страница
// Лонгрид: 5 h2-блоков, h3-подзаголовки, расширенная таблица платёжных методов
// Источник: «Анализ самых конкурентных сайтов» — LSI-матрицы, N-граммы, декомпозиция болей
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear, getBuildDateISO, getBuildDateFull } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();
const buildISO   = getBuildDateISO();
const buildFull  = getBuildDateFull();

const casinos = [...casinosRaw].sort((a, b) => b.rating - a.rating);

// ── FAQ: 4 коммерческих вопроса, развёрнутые ответы с N-граммами ─────────────
const faqItems = [
  {
    q: 'Какие казино из рейтинга лучших онлайн обеспечивают моментальный вывод?',
    a: `Рейтинг лучших онлайн казино ${buildYear} года включает площадки, где кешаут через СБП и крипто-кошельки (USDT TRC20, TON, Litecoin) занимает до 15 минут. Норматив отбора: заявка обрабатывается в автоматическом режиме без ручного финмониторинга. Банковские карты (Мир, Visa) — до 3–6 часов. Электронные кошельки Piastrix и ЮMoney — до 30 минут. Все площадки из топ-10 прошли тестовые кешауты инкогнито с суммами от 1 000 до 50 000 рублей. Казино с задержками выплат свыше 24 часов получают статус «под наблюдением» и опускаются в нижнюю часть списка.`,
  },
  {
    q: 'В каких казино можно играть на реальные деньги без верификации паспорта?',
    a: `Играть на реальные деньги без верификации паспорта позволяют более 80% казино из текущего рейтинга — до достижения лимита вывода эквивалентом 1 000 $. KYC (Know Your Customer) запрашивается только при подозрении на мультиаккаунтинг, профессиональный бонусхантинг или при снятии сверхкрупных джекпотов свыше 100 000 рублей. Крипто-шлюзы (TRC20, TON, Litecoin) обеспечивают анонимность транзакций на уровне блокчейна без привязки к персональным данным. Казино, требующие скан паспорта при первом депозите от 500 рублей, автоматически исключаются из нашего рейтинга.`,
  },
  {
    q: 'Как отличить лицензионные слоты от скриптовых аппаратов с подкрученным RTP?',
    a: `Лицензионные игровые автоматы загружаются строго с CDN официальных провайдеров: Pragmatic Play, Nolimit City, Hacksaw Gaming, Play'n GO. Проверка: откройте DevTools → вкладку Network, запустите слот и убедитесь, что домен загрузки .js и .json файлов игры совпадает с доменом провайдера (например, pragmaticplay.net), а не зеркалом казино. Скриптовый софт подменяет RNG на сервере оператора, занижая реальную отдачу до 60–80% при задекларированных 96–97%. ГСЧ в оригинальном лицензионном ПО сертифицируется аудиторами eCOGRA или iTech Labs каждые 6–12 месяцев. Сертификат с актуальной датой должен быть опубликован в разделе «О казино» или «Честность».`,
  },
  {
    q: 'Можно ли начать играть на реальные деньги с минимальным бюджетом — депозиты от 100 рублей?',
    a: `В рейтинге представлены казино с минимальным депозитом от 100 рублей через СБП или P2P-перевод. Для лоуроллеров (игроков с минимальным бюджетом) оптимальны слоты с низкой волатильностью (разброс RTP ±3% от среднего), ставкой от 1–2 рублей за спин и отсутствием минимального множителя для отыгрыша бонуса. Бездепозитные фриспины за регистрацию (30–50 FS) позволяют протестировать реальные выплаты без стартового взноса. Стратегия банкролл-менеджмента для старта: не превышать 5% бюджета за одну ставку, выбирать аппараты с Hit Rate (частотой выплат) выше 35%.`,
  },
