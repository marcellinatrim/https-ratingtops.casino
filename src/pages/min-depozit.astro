---
// src/pages/min-depozit.astro — Казино с минимальным депозитом
// ФИЛЬТР: min_deposit <= 100
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();

const MAX_DEPOSIT = 100;
const casinos = [...casinosRaw]
  .filter(c => c.min_deposit <= MAX_DEPOSIT)
  .sort((a, b) => b.rating - a.rating);

const minActual = Math.min(...casinos.map(c => c.min_deposit));

const faqItems = [
  {
    q: 'В каком казино самый маленький минимальный депозит?',
    a: `На этой странице собраны казино с депозитом до ${MAX_DEPOSIT} рублей. Минимальный порог входа среди представленных площадок — ${minActual} рублей.`,
  },
  {
    q: 'Зачем играть в казино с маленьким депозитом?',
    a: 'Небольшой депозит снижает риски для новых игроков. Вы проверяете платёжные системы, скорость выплат и честность площадки, не вкладывая крупные суммы.',
  },
  {
    q: 'Можно ли получить бонус при минимальном депозите?',
    a: 'Да, большинство казино начисляют бонус на первый депозит независимо от его размера. Сумма бонуса пропорциональна пополнению.',
  },
];
---

<BaseLayout
  title={`Казино с минимальным депозитом до ${MAX_DEPOSIT} ₽ — Рейтинг ${buildYear}`}
  description={`Топ казино с минимальным депозитом до ${MAX_DEPOSIT} рублей. Найдено ${casinos.length} площадок с низким порогом входа и выгодными бонусами. Обновлено: ${buildMonth}.`}
  activePage="/min-depozit"
>

  <section id="hero">
    <div class="container">
      <h1>Казино с <em>минимальным депозитом</em> до {MAX_DEPOSIT} ₽</h1>
      <p>
        Найдено {casinos.length} казино с низким порогом входа.
        Начните играть с минимальными вложениями и получайте бонусы.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Казино с депозитом до {MAX_DEPOSIT} рублей ({casinos.length} шт.)</h2>
      <div class="page-meta">
        <span class="page-meta__badge">Депозит ≤ {MAX_DEPOSIT} ₽</span>
        <span>Найдено: {casinos.length} казино</span>
      </div>
      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content">
    <div class="container">
      <h2>Казино с минимальным депозитом: что важно знать в {buildYear} году?</h2>
      <p>
        Онлайн-казино с низким порогом входа идеально подходят для начинающих.
        Вы можете протестировать площадку без крупных вложений.
      </p>
      <h3>Как пополнить счёт на минимальную сумму?</h3>
      <p>
        Большинство казино принимают оплату через СБП, карты Мир, ЮMoney и криптовалюту.
        Крипта позволяет пополнить счёт без ограничений по минимальной сумме.
      </p>
      <h3>Влияет ли размер депозита на бонус?</h3>
      <p>
        Процент бонуса не зависит от суммы депозита. Если казино даёт 100% бонус — вы получите
        его и на 50, и на 500 рублей. Абсолютная сумма будет пропорционально меньше.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} heading="FAQ: Казино с минимальным депозитом" />

</BaseLayout>
