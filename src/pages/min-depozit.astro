---
// src/pages/min-depozit.astro — Казино с минимальным депозитом
// ФИЛЬТР: min_deposit <= 100
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';

// ---- ЛОГИКА КЛАСТЕРА ----
const MAX_DEPOSIT = 100;
const casinos = [...casinosRaw]
  .filter(c => c.min_deposit <= MAX_DEPOSIT)
  .sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: 'В каком казино самый маленький минимальный депозит?',
    a: `На этой странице собраны казино с минимальным депозитом до ${MAX_DEPOSIT} рублей. Среди представленных вариантов минимальный порог входа составляет ${Math.min(...casinos.map(c => c.min_deposit))} рублей.`,
  },
  {
    q: 'Зачем играть в казино с маленьким депозитом?',
    a: 'Небольшой депозит снижает риски для новых игроков. Вы можете проверить платёжные системы, скорость выплат и честность площадки, не вкладывая крупные суммы.',
  },
  {
    q: 'Можно ли получить бонус при минимальном депозите?',
    a: 'Да, большинство казино в нашем списке начисляют бонус на первый депозит независимо от его размера. Сумма бонуса пропорциональна пополнению.',
  },
];
---

<BaseLayout
  title={`Казино с минимальным депозитом до ${MAX_DEPOSIT} ₽ — Рейтинг 2024`}
  description={`Топ казино с минимальным депозитом до ${MAX_DEPOSIT} рублей. Найдено ${casinos.length} площадок с низким порогом входа и выгодными бонусами.`}
  activePage="/min-depozit"
>

  <!-- 1. HERO -->
  <section id="hero">
    <div class="container">
      <h1>Казино с <em>минимальным депозитом</em> до {MAX_DEPOSIT} ₽</h1>
      <p>
        Найдено {casinos.length} казино с низким порогом входа.
        Начните играть с минимальными вложениями и получайте бонусы.
      </p>
    </div>
  </section>

  <!-- 2. РЕЙТИНГ — отфильтрованный список -->
  <section id="rating">
    <div class="container">
      <h2>Казино с депозитом до {MAX_DEPOSIT} рублей ({casinos.length} шт.)</h2>

      <div class="page-meta">
        <span class="page-meta__badge">Фильтр: депозит ≤ {MAX_DEPOSIT} ₽</span>
        <span>Найдено: {casinos.length} казино</span>
      </div>

      {casinos.length > 0 ? (
        <div class="rating-list" role="list">
          {casinos.map((casino, index) => (
            <div role="listitem">
              <CasinoCard casino={casino} rank={index + 1} />
            </div>
          ))}
        </div>
      ) : (
        <p>По заданным критериям казино не найдены.</p>
      )}
    </div>
  </section>

  <!-- 3. SEO-КОНТЕНТ -->
  <section id="seo-content">
    <div class="container">
      <h2>Казино с минимальным депозитом: что важно знать</h2>
      <p>
        Онлайн-казино с низким порогом входа идеально подходят для начинающих игроков.
        Вы можете протестировать площадку, не рискуя крупными суммами.
        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>

      <h3>Как пополнить счёт на минимальную сумму?</h3>
      <p>
        Большинство казино из нашего рейтинга принимают оплату через популярные российские
        платёжные системы: Qiwi, ЮMoney, СБП, карты Мир. Также доступна криптовалюта —
        она позволяет пополнить счёт без ограничений по минимальной сумме.
      </p>

      <h3>Влияет ли размер депозита на бонус?</h3>
      <p>
        Процент бонуса не зависит от суммы депозита — если казино предлагает 100% бонус,
        вы получите его как на 50, так и на 500 рублей. Однако абсолютная сумма бонуса
        будет пропорционально меньше при минимальном депозите.
      </p>
    </div>
  </section>

  <!-- 4. FAQ -->
  <FAQ items={faqItems} heading="FAQ: Казино с минимальным депозитом" />

</BaseLayout>
