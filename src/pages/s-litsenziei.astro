---
// src/pages/s-litsenziei.astro — Казино с лицензией
// ФИЛЬТР: has_license === true
import BaseLayout from '../layouts/BaseLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import FAQ from '../components/FAQ.astro';
import casinosRaw from '../data/casinos.json';
import { getBuildMonth, getBuildYear } from '../utils/date';

const buildMonth = getBuildMonth();
const buildYear  = getBuildYear();

const casinos = [...casinosRaw]
  .filter(c => c.has_license === true)
  .sort((a, b) => b.rating - a.rating);

const faqItems = [
  {
    q: 'Что даёт лицензия казино игроку?',
    a: 'Лицензия означает, что казино прошло проверку регулятора: RNG сертифицирован, выплаты гарантированы, данные игроков защищены. Это значительно снижает риск мошенничества.',
  },
  {
    q: 'Какие лицензии считаются наиболее надёжными?',
    a: 'Наиболее авторитетные лицензии выдают Malta Gaming Authority (MGA), UK Gambling Commission и Curaçao eGaming. Казино с лицензией MGA или UKGC считаются наиболее надёжными.',
  },
  {
    q: 'Как проверить лицензию казино самостоятельно?',
    a: 'Номер лицензии указывается в подвале сайта казино. Его можно проверить на официальном сайте регулятора. Все казино в нашем рейтинге прошли эту проверку.',
  },
];
---

<BaseLayout
  title={`Лицензированные казино ${buildYear} — Рейтинг надёжных площадок`}
  description={`${casinos.length} казино с действующей лицензией. Проверенные площадки с гарантированными выплатами и защитой игрока. Обновлено: ${buildMonth}.`}
  activePage="/s-litsenziei"
>

  <section id="hero">
    <div class="container">
      <h1>Казино <em>с лицензией</em> — только проверенные площадки</h1>
      <p>
        {casinos.length} казино с действующей лицензией.
        Гарантированные выплаты и честная игра.
      </p>
    </div>
  </section>

  <section id="rating">
    <div class="container">
      <h2>Лицензированные казино {buildYear} ({casinos.length} шт.)</h2>
      <div class="page-meta">
        <span class="page-meta__badge">✅ Лицензия подтверждена</span>
        <span>Найдено: {casinos.length} казино</span>
      </div>
      <div class="rating-list" role="list">
        {casinos.map((casino, index) => (
          <div role="listitem">
            <CasinoCard casino={casino} rank={index + 1} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="seo-content">
    <div class="container">
      <h2>Почему важно играть в лицензированных казино?</h2>
      <p>
        Лицензия — гарантия того, что казино работает по правилам под надзором регулятора.
        Нелицензированные площадки могут заморозить счёт без объяснений.
      </p>
      <h3>Как регулятор защищает игроков?</h3>
      <p>
        При наличии лицензии игрок вправе подать официальную жалобу регулятору, если казино
        отказывает в выплате. Регулятор проводит расследование и может отозвать лицензию нарушителя.
      </p>
      <h3>Лицензия и честность RNG</h3>
      <p>
        Генератор случайных чисел в лицензированных казино регулярно тестируется независимыми
        аудиторами (eCOGRA, BMM Testlabs). Это гарантирует честность каждого спина и заявленный RTP.
      </p>
    </div>
  </section>

  <FAQ items={faqItems} heading="FAQ: Казино с лицензией" />

</BaseLayout>
